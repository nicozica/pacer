# Comma-separated list of URLs to capture
TARGET_PAGES=https://example.com

# Path to Playwright auth state file (optional).
# If this file exists, its session cookies/storage will be loaded.
# Generate it with: npx playwright codegen --save-storage=storage/auth/state.json
AUTH_STATE_FILE=storage/auth/state.json

# Set to false to run in headed mode (useful for debugging)
HEADLESS=true

# Root directory for all runtime storage
STORAGE_DIR=storage

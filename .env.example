# --- Web server ---

# Host and port for the local web interface
WEB_HOST=127.0.0.1
WEB_PORT=3000

# Optional fallback location for weather lookups when activity coordinates are missing
WEATHER_DEFAULT_LAT=
WEATHER_DEFAULT_LON=

# --- Strava API ---

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# The redirect URI registered in your Strava API application settings.
# For a local CLI flow, http://localhost is fine — no server needed.
STRAVA_REDIRECT_URI=http://localhost

# Where OAuth tokens are stored (access_token, refresh_token, expires_at).
# If empty, defaults to <STORAGE_DIR>/auth/strava-tokens.json.
# Different from the Playwright browser session in <STORAGE_DIR>/auth/strava.json.
STRAVA_TOKENS_FILE=

# Number of activities to fetch per run (max 200 per Strava API limits)
STRAVA_ACTIVITIES_PER_PAGE=30

# --- Playwright capture (optional / secondary) ---

# Comma-separated list of URLs to capture as screenshots
TARGET_PAGES=https://www.strava.com/dashboard

# Playwright browser session state (generated by `npm run auth:strava`)
# If empty, defaults to <STORAGE_DIR>/auth/strava.json.
AUTH_STATE_FILE=

# Set to false to run Chromium in headed mode (useful for debugging)
HEADLESS=true

# Root directory for all runtime storage
STORAGE_DIR=storage

# SQLite database file for session storage
DATABASE_FILE=

# Local export directory for CMS snapshots consumed later by run.nico.ar
CMS_EXPORT_DIR=

# --- run.nico.ar publish hook ---

# Local script triggered by "Save and publish"
RUN_SITE_DEPLOY_SCRIPT=

# Deploy target for the static public site
# Defaults to pizero:/srv/data/www/run.nico.ar/
RUN_SITE_DEPLOY_TARGET=

# Public URL used for final production verification
RUN_SITE_PUBLIC_URL=https://run.nico.ar

# Timeout for build + deploy + verification
RUN_SITE_DEPLOY_TIMEOUT_MS=300000

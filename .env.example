# Comma-separated list of URLs to capture
TARGET_PAGES=https://www.strava.com/dashboard

# Path to the Playwright auth state file to load before capturing (optional).
# Use one of the files generated by the auth scripts:
#   storage/auth/strava.json
#   storage/auth/garmin.json
AUTH_STATE_FILE=storage/auth/strava.json

# Set to false to run in headed mode (useful for debugging)
HEADLESS=true

# Root directory for all runtime storage
STORAGE_DIR=storage

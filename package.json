{
  "name": "pacer",
  "version": "0.1.0",
  "description": "Personal running workflow assistant",
  "scripts": {
    "web": "npm run dev:web",
    "dev:web": "ts-node --transpile-only src/web/server.ts",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.runtime.json",
    "build:all": "tsc -p tsconfig.json",
    "start": "node dist/web/server.js",
    "start:prod": "node dist/web/server.js",
    "sessions:publish": "ts-node --transpile-only src/session/publish-cli.ts",
    "sessions:rebuild-splits": "ts-node --transpile-only src/session/rebuild-km-splits-cli.ts",
    "sessions:seed": "ts-node --transpile-only src/session/seed-cli.ts",
    "sessions:seed:prod": "node dist/session/seed-cli.js",
    "strava:auth:prod": "node dist/strava/auth-cli.js",
    "strava:fetch:prod": "node dist/strava/fetch-cli.js",
    "strava:auth": "ts-node --transpile-only src/strava/auth-cli.ts",
    "strava:fetch": "ts-node --transpile-only src/strava/fetch-cli.ts",
    "auth:strava": "ts-node --transpile-only src/auth/login.ts strava",
    "auth:garmin": "ts-node --transpile-only src/auth/login.ts garmin",
    "capture": "ts-node --transpile-only src/capture/runner.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.0",
    "playwright": "^1.42.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
